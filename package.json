{
  "name": "auronix",
  "version": "1.0.0",
  "private": true,
  "description": "Auronix Technologies — Cybersecurity Services & Client Portal",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n FE,BE -c cyan,green \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w frontend",
    "lint": "npm run lint -w frontend",
    "db:migrate": "npm run db:migrate -w backend",
    "db:seed": "npm run db:seed -w backend",
    "db:studio": "npx prisma studio --schema=backend/prisma/schema.prisma"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
