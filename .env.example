# ═══════════════════════════════════════════════════════════════
# HexaShield Security — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in all values.
# NEVER commit the .env file to version control.
# ═══════════════════════════════════════════════════════════════

# ── General ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (PostgreSQL) ─────────────────────────────────────
# Local: postgresql://user:password@localhost:5432/hexashield
# Railway: provided by Railway PostgreSQL add-on
# Supabase: provided in Supabase dashboard
DATABASE_URL=postgresql://postgres:password@localhost:5432/hexashield

# ── JWT (RS256 — Asymmetric Keys) ─────────────────────────────
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the contents here (use \n for newlines)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
JWT_EXPIRY=15m
JWT_ISSUER=hexashield.in

# ── Refresh Token ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
REFRESH_TOKEN_SECRET=your_64_byte_hex_random_secret_here
REFRESH_EXPIRY=7d

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── GitHub Report Storage ─────────────────────────────────────
# Create a private GitHub repo for report storage
# Generate a Personal Access Token (PAT) with 'repo' scope
GITHUB_STORAGE_OWNER=your-github-username
GITHUB_STORAGE_REPO=hexashield-reports
GITHUB_STORAGE_TOKEN=ghp_your_personal_access_token_here
GITHUB_STORAGE_BRANCH=main

# ── Email (Resend) ────────────────────────────────────────────
# Sign up at https://resend.com and get API key
# Or use SMTP settings below instead
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=HexaShield Security <hello@hexashield.in>

# ── Email (SMTP — alternative to Resend) ──────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ── Frontend URL ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
