{
  "buildCommand": "npm run build -w frontend",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://YOUR_RAILWAY_URL/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
